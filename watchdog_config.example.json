{
  "_comment": "webhook_url 和邮箱密码请通过环境变量设置，不要写在这里。邮箱密码使用 EMAIL_PASSWORD 环境变量，163/QQ 邮箱请使用授权码而非登录密码。",
  "check_interval": 180,
  "notify": {
    "wecom": {
      "enabled": true,
      "webhook_url": ""
    },
    "feishu": {
      "enabled": false,
      "webhook_url": ""
    },
    "dingtalk": {
      "enabled": false,
      "webhook_url": ""
    },
    "desktop": {
      "enabled": true
    },
    "logfile": {
      "enabled": true,
      "path": "/home/user189/model_train/logs_bw_sweep/watchdog_alerts.log"
    },
    "email": {
      "enabled": false,
      "smtp_server": "smtp.163.com",
      "smtp_port": 465,
      "sender": "你的邮箱@163.com",
      "password": "",
      "receivers": ["接收告警的邮箱@xxx.com"],
      "use_ssl": true
    }
  },
  "monitor": {
    "process_pattern": "python.*train_yhk",
    "log_patterns": [
      "/home/user189/model_train/logs_bw_sweep/*.log",
      "/home/user189/model_train/logs/*.log"
    ],
    "error_keywords": [
      "Error",
      "Exception",
      "Traceback",
      "OOM",
      "CUDA error",
      "RuntimeError",
      "out of memory",
      "Segmentation fault",
      "core dumped",
      "killed",
      "NaN",
      "inf loss"
    ],
    "orchestrator_pattern": "train_bw_sweep\\|train_vae_hist_param_sweep\\|train_labelclip",
    "gpu_idle_threshold": 3
  }
}
